# Home Media Server - Environment Configuration
# Copy this file to .env and fill in your actual values
# NEVER commit .env to git - it's in .gitignore
#
# SECURITY NOTICE: This stack is Tailscale-only (no port forwarding).
# All services are accessed via Tailscale VPN through TSDProxy.
# Do NOT expose ports to the internet.

###############################################
# SYSTEM SETTINGS
###############################################
PUID=1000
PGID=1000
TZ=America/Toronto
DNS_1=1.1.1.1
DNS_2=1.0.0.1

###############################################
# TAILSCALE REVERSE PROXY (REQUIRED)
###############################################
# Get your auth key from: https://login.tailscale.com/admin/settings/keys
# Create a reusable auth key that doesn't expire
TSDPROXY_AUTHKEY=tskey-auth-XXXXXXXXXXXXXXXXXX
# Your Tailscale server IP (run: tailscale ip -4)
TSDPROXY_HOSTNAME=100.0.0.1

###############################################
# PLEX CONFIGURATION (if using Plex)
###############################################
# IMPORTANT: Get your claim token at https://www.plex.tv/claim/ (valid for 4 minutes)
# Leave blank to set up manually via WebUI first, then claim later
PLEX_CLAIM_TOKEN=claim-XXXXXXXXXXXXXXXXXX

###############################################
# DATA PATHS
###############################################
# /data/media/ should contain:
#   - movies/
#   - tv/
#   - music/
#   - books/ (for Readarr)
# /data/torrents/ should contain:
#   - movies/
#   - tv/
#   - music/
#   - books/

###############################################
# AUTHENTICATION REQUIREMENTS
###############################################
# Services accessed ONLY via Tailscale - no internet exposure

# qBittorrent:
#   - Default: admin / adminpass
#   - CHANGE ON FIRST RUN via Web UI
#   - Tools → Options → Web UI → Username/Password

# Jellyfin:
#   - No login configured initially
#   - CREATE ACCOUNT on first access via Tailscale link
#   - Essential for security

# Plex:
#   - Requires Plex paid subscription
#   - Login with your Plex account
#   - Set up via claim token above or manual account linking

# Radarr/Sonarr/Lidarr/Readarr:
#   - No web UI password by default
#   - Access controlled via API key
#   - Recommend setting password in Settings → General

# Prowlarr:
#   - No password by default
#   - API key available in Settings
#   - Recommend enabling password protection

# Bazarr:
#   - No password by default
#   - Recommend enabling in Settings

# Termix/Dockhand:
#   - NO BUILT-IN AUTHENTICATION
#   - Accessible to anyone on your Tailscale network
#   - Consider disabling if not regularly used
#   - Future: Implement Authelia for reverse proxy auth
